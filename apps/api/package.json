{
  "name": "@todos/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "yarn workspace @todos/core build && yarn workspace @todos/shared build",
    "prestart": "yarn workspace @todos/core build && yarn workspace @todos/shared build",
    "prestart:dev": "yarn workspace @todos/core build && yarn workspace @todos/shared build",
    "prestart:debug": "yarn workspace @todos/core build && yarn workspace @todos/shared build",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts --watch",
    "test:cov": "vitest run --config vitest.config.ts --coverage",
    "test:debug": "vitest --config vitest.config.ts --inspect-brk --inspect --single-thread",
    "test:e2e": "vitest run --config vitest.config.ts --include \"**/*.e2e-spec.ts\"",
    "deps:build": "yarn workspace @todos/core build && yarn workspace @todos/shared build"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^8.0.0",
    "@todos/core": "workspace:*",
    "@todos/firebase": "workspace:*",
    "@todos/shared": "workspace:*",
    "@todos/store": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@vitest/ui": "latest",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "latest"
  }
}
