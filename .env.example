# ── API / NestJS ──────────────────────────────────────────────────────────────
PORT=3000

# ── Firebase credentials (required for the API service) ──────────────────────
# Provide ONE of the following credential strategies (recommended: Option C or
# a base64-encoded Option A to avoid newline/escaping issues):
#
# Option A – raw service-account JSON (preferred as base64):
#   Encode for use in .env (avoid committing raw JSON):
#     export FIREBASE_SERVICE_ACCOUNT_JSON=$(cat firebase-service-key.json | base64 -w0)
#   At runtime (Node):
#     JSON.parse(Buffer.from(process.env.FIREBASE_SERVICE_ACCOUNT_JSON, 'base64').toString())
FIREBASE_SERVICE_ACCOUNT_JSON=
#
# Option B – individual fields (less preferred; may require escaping private key newlines):
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Option C – local credentials file (Application Default Credentials):
#   Recommended for local development: keep the credentials file outside version
#   control and point to it via `GOOGLE_APPLICATION_CREDENTIALS`.
GOOGLE_APPLICATION_CREDENTIALS=${PWD}/firebase-service-key.json

# NOTE: Do NOT commit service account keys, private credentials, or `.env` files
# containing secrets to version control. Use `.env.local` for personal overrides
# and add it to `.gitignore`.

FIREBASE_TODOS_COLLECTION=todos
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# ── MCP service ───────────────────────────────────────────────────────────────
# URL of the Todos API as seen from the MCP process.
# When running locally (outside Docker): http://localhost:3000
# When running inside Docker Compose:    http://api:3000  (set automatically)
TODOS_API_URL=http://localhost:3000

# ── Web app ───────────────────────────────────────────────────────────────────
# Vite requires the VITE_ prefix.  This URL is resolved by the *browser*, so it
# must always be a host-facing address (http://localhost:3000), not a Docker
# network name.
# If you change API_PORT, update this value to match (e.g. http://localhost:3001).
VITE_TODOS_API_URL=http://localhost:3000

# ── Mobile app ────────────────────────────────────────────────────────────────
# Expo requires the EXPO_PUBLIC_ prefix.
# If you change API_PORT, update this value to match (e.g. http://localhost:3001).
EXPO_PUBLIC_TODOS_API_URL=http://localhost:3000

# ── Docker Compose port overrides (optional) ──────────────────────────────────
# Uncomment and change these to remap host ports when the defaults conflict.
# API_PORT=3000
# MCP_PORT=3010
# WEB_PORT=5173

