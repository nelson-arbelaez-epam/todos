{
  "name": "todos",
  "packageManager": "yarn@4.12.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:packages": "yarn workspaces foreach -At --include @todos/core --include @todos/store --include @todos/firebase --include @todos/branding run build",
    "build:apps": "yarn workspaces foreach -Ap --include @todos/api --include @todos/mcp --include @todos/web run build",
    "build:all": "yarn build:packages && yarn build:apps",
    "build:api": "yarn build:packages && yarn workspace @todos/api build",
    "build:mcp": "yarn build:packages && yarn workspace @todos/mcp build",
    "build:web": "yarn workspace @todos/web build",
    "start:api": "yarn workspace @todos/api start",
    "start:mcp": "yarn workspace @todos/mcp start",
    "dev:packages": "yarn workspaces foreach -Ap -i --include @todos/core --include @todos/store --include @todos/firebase --include @todos/branding run dev",
    "dev:api": "yarn workspace @todos/api dev",
    "dev:mcp": "yarn workspace @todos/mcp dev",
    "dev:web": "yarn workspace @todos/web dev",
    "dev:mobile": "yarn workspace @todos/mobile start",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "test": "vitest run --config vitest.workspace.config.ts",
    "test:ui": "vitest --config vitest.workspace.config.ts --ui"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@swc/core": "^1.15.21",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "latest",
    "unplugin-swc": "^1.5.9",
    "vitest": "latest"
  }
}
