.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Build outputs
dist
build
coverage

# Firebase CLI debug logs
firebase-debug.log

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# dotenv environment variable files
.env*
!.env.example

# Service key files
*key*.json

# E2E test report artifacts (directory is tracked via .gitkeep)
tools/e2e/reports/*.xml
tools/e2e/reports/*.json
tools/e2e/reports/*.html
tools/e2e/reports/junit-*.xml

# Playwright report outputs
apps/web/playwright-report/
apps/web/test-results/

# Maestro report outputs
apps/mobile/e2e/reports/