{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${input:github_mcp_pat}"
      }
    },
    "todos": {
      "type": "http",
      "url": "http://localhost:3010/mcp/",
      "headers": {
        "Content-Type": "application/json",
        "x-api-key": "${input:todos_api_key}"
      }
    }
  },
  "inputs": [
    {
      "type": "promptString",
      "id": "github_mcp_pat",
      "description": "GitHub Personal Access Token",
      "password": true
    },
    {
      "type": "promptString",
      "id": "todos_api_key",
      "description": "Todos API Key",
      "password": true
    }
  ]
}
